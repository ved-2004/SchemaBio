# ══════════════════════════════════════════════════════════
# AIDEN Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────
# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional: higher PubMed rate limits ──────────────────
# Register free at https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# ── RAG datasets (no API keys required — all public) ─────
# CARD  : https://card.mcmaster.ca/latest/data  (tar.bz2, ~4.6 MB, no auth)
# AlphaFold : https://alphafold.ebi.ac.uk/api/  (no auth)
# IMGT  : https://www.imgt.org/genedb/          (no auth; SSL bypass enabled)
# ChromaDB vector store persists to: SchemaBio/backend/data/chromadb/

# ── Optional: Semantic Scholar citations ─────────────────
# Register free at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=

# ── Supabase (cloud storage + uploads database) ───────────
# Create a project at https://supabase.com
# Settings → API → Project URL and service_role secret key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Storage bucket name (create it in Supabase Storage → New bucket)
SUPABASE_BUCKET=schemabio-uploads
# How many days before uploaded files expire (default: 30)
UPLOAD_TTL_DAYS=30
#
# ── Supabase SQL — run ALL of this once in the SQL Editor ─
#
#   -- Users (auth)
#   create table if not exists users (
#     id             uuid primary key default gen_random_uuid(),
#     google_id      text not null unique,
#     email          text not null,
#     name           text not null,
#     avatar_url     text,
#     phone_number   text,
#     created_at     timestamptz not null default now(),
#     last_login_at  timestamptz not null default now()
#   );
#   create unique index if not exists users_google_id_idx on users(google_id);
#   create unique index if not exists users_email_idx    on users(email);
#
#   -- Uploaded files
#   create table if not exists user_uploads (
#     id              uuid primary key default gen_random_uuid(),
#     upload_id       text not null unique,
#     user_id         text not null,
#     filename        text not null,
#     file_size_bytes bigint not null default 0,
#     bucket_path     text not null,
#     program_id      text,
#     uploaded_at     timestamptz not null default now(),
#     expires_at      timestamptz not null
#   );
#   create index if not exists user_uploads_user_id_idx  on user_uploads(user_id);
#   create index if not exists user_uploads_expires_at_idx on user_uploads(expires_at);

# ── Google OAuth2 (sign-in) ───────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable "Google+ API" and create OAuth 2.0 credentials.
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (session signing) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Service URLs ──────────────────────────────────────────
# Backend public URL (used to build OAuth callback URI)
BACKEND_URL=http://localhost:8000
# Frontend public URL (used to redirect after login/logout)
FRONTEND_URL=http://localhost:5173

# ── Application settings ──────────────────────────────────
# Use demo data always (no live PubMed queries)
DEMO_MODE=false

# Backend port
PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
